; Engine configuration file.
; Open with Godot 4.6+ (free download at https://godotengine.org).
;
; First run: open this file in Godot, then F5 to play.
; For Android: install the Android export template (Editor > Manage Export
; Templates), set SDK paths in Editor Settings, then Project > Export.

config_version=5

[application]

config/name="Inkland"
config/description="Claim the arena. Leave your trail, close the loop, paint the map your colour — but don't let anyone cross your line. An original take on the territory-capture arena."
config/version="1.0.0"
run/main_scene="res://scenes/Home.tscn"
config/features=PackedStringArray("4.6", "Mobile")
config/icon="res://icon.svg"
boot_splash/bg_color=Color(0.12, 0.13, 0.16, 1)
boot_splash/show_image=false

[autoload]

Game="*res://scripts/Game.gd"
Sfx="*res://scripts/Sfx.gd"
Ads="*res://scripts/Ads.gd"
DevShot="*res://scripts/DevShot.gd"

[display]

window/size/viewport_width=720
window/size/viewport_height=1280
window/stretch/mode="viewport"
window/stretch/aspect="keep_height"
window/handheld/orientation=1            ; 0 landscape, 1 portrait

[input_devices]

pointing/emulate_touch_from_mouse=true

[internationalization]

locale/fallback="en"
locale/translations=PackedStringArray("res://assets/translations/strings.en.translation", "res://assets/translations/strings.de.translation", "res://assets/translations/strings.fr.translation", "res://assets/translations/strings.it.translation", "res://assets/translations/strings.es.translation", "res://assets/translations/strings.pt.translation", "res://assets/translations/strings.nl.translation", "res://assets/translations/strings.pl.translation", "res://assets/translations/strings.tr.translation", "res://assets/translations/strings.cs.translation", "res://assets/translations/strings.sk.translation", "res://assets/translations/strings.sv.translation", "res://assets/translations/strings.da.translation", "res://assets/translations/strings.nb.translation", "res://assets/translations/strings.fi.translation", "res://assets/translations/strings.hu.translation", "res://assets/translations/strings.ro.translation", "res://assets/translations/strings.ru.translation", "res://assets/translations/strings.uk.translation", "res://assets/translations/strings.el.translation", "res://assets/translations/strings.id.translation", "res://assets/translations/strings.vi.translation")

[rendering]

renderer/rendering_method="mobile"
textures/vram_compression/import_etc2_astc=true
